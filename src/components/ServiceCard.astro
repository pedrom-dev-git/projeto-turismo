---
interface Props {
  title: string;
  description: string;
  gradient: string;
}

const { title, description, gradient } = Astro.props;
---

<div class="group relative rounded-2xl overflow-hidden shadow-lg h-72">
  <!-- Placeholder gradient background -->
  <div class={`absolute inset-0 ${gradient}`}></div>
  <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors"></div>
  <div class="relative h-full flex flex-col justify-end p-6 text-white">
    <h3 class="text-xl font-bold mb-2">{title}</h3>
    <p class="text-white/80 text-sm mb-3">{description}</p>
    <a href="#" class="text-sm font-semibold hover:underline">saiba mais &rarr;</a>
  </div>
</div>
