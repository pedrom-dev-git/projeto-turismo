---
const partners = ["Cozybnb", "Serendipity", "Hideaway", "Earthly", "The Nook", "Horizon"];
---

<section class="py-16">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center uppercase mb-12">
      Nossos Parceiros
    </h2>

    <div class="swiper partners-swiper">
      <div class="swiper-wrapper items-center">
        {partners.map((name) => (
          <div class="swiper-slide !w-auto px-8">
            <div class="text-xl font-semibold text-medium-gray/60 select-none whitespace-nowrap">
              {name}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Autoplay } from "swiper/modules";
  import "swiper/css";

  new Swiper(".partners-swiper", {
    modules: [Autoplay],
    slidesPerView: "auto",
    loop: true,
    speed: 3000,
    autoplay: {
      delay: 0,
      disableOnInteraction: false,
    },
    freeMode: true,
  });
</script>
