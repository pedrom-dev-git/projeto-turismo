---
const news = [
  { title: "Praia do Rosa", subtitle: "Sul de Santa Catarina", gradient: "from-cyan-600 to-blue-900" },
  { title: "Balneário Camboriú", subtitle: "Litoral catarinense", gradient: "from-blue-500 to-indigo-900" },
  { title: "Serra Gaúcha", subtitle: "Rio Grande do Sul", gradient: "from-emerald-600 to-green-900" },
  { title: "Florianópolis", subtitle: "Ilha da Magia", gradient: "from-teal-500 to-cyan-900" },
  { title: "Bombinhas", subtitle: "Capital do mergulho", gradient: "from-sky-500 to-blue-800" },
];
---

<section id="novidades" class="py-16 bg-dark">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-white">Feature News</h2>
      <div class="flex gap-3">
        <button class="news-prev w-10 h-10 rounded-full border border-white/30 text-white flex items-center justify-center hover:bg-white/10 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button class="news-next w-10 h-10 rounded-full border border-white/30 text-white flex items-center justify-center hover:bg-white/10 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <div class="swiper news-swiper">
      <div class="swiper-wrapper">
        {news.map((item) => (
          <div class="swiper-slide">
            <div class={`relative rounded-2xl overflow-hidden h-64 bg-gradient-to-br ${item.gradient}`}>
              <div class="absolute inset-0 bg-black/20"></div>
              <div class="relative h-full flex flex-col justify-end p-6 text-white">
                <h3 class="text-lg font-bold">{item.title}</h3>
                <p class="text-white/70 text-sm">{item.subtitle}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation } from "swiper/modules";
  import "swiper/css";

  new Swiper(".news-swiper", {
    modules: [Navigation],
    slidesPerView: 1,
    spaceBetween: 20,
    navigation: {
      prevEl: ".news-prev",
      nextEl: ".news-next",
    },
    breakpoints: {
      640: { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });
</script>
