---
const whatsappNumber = "5548999503368";
---

<section class="relative min-h-[600px] flex items-center bg-gradient-to-br from-dark via-primary/30 to-dark">
  <!-- Phone bar -->
  <div class="absolute top-4 right-4 md:right-8 flex items-center gap-2 text-white text-sm">
    <svg class="w-4 h-4 text-green-400" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.12.553 4.11 1.519 5.838L.057 23.616l5.932-1.556A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818c-1.94 0-3.79-.508-5.417-1.466l-.388-.231-4.025 1.055 1.074-3.922-.253-.402A9.778 9.778 0 012.182 12 9.818 9.818 0 0112 2.182 9.818 9.818 0 0121.818 12 9.818 9.818 0 0112 21.818z"/>
    </svg>
    <a href={`https://wa.me/${whatsappNumber}`} class="hover:underline">+48 999503368</a>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-20 w-full">
    <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12 max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-bold text-primary mb-3">
        Sua Jornada Começa Aqui!
      </h1>
      <p class="text-medium-gray mb-8">
        Atendimento personalizado para transporte escolar e viagens em grupo.
      </p>

      <form id="hero-form" class="flex flex-col md:flex-row gap-4 items-stretch">
        <select name="tipo" class="flex-1 border border-gray-300 rounded-lg px-4 py-3 text-sm bg-white">
          <option value="">Tipo de Serviço</option>
          <option value="escolar">Transporte Escolar</option>
          <option value="turismo">Turismo e Viagens</option>
        </select>

        <input
          type="text"
          name="origem"
          placeholder="Origem"
          class="flex-1 border border-gray-300 rounded-lg px-4 py-3 text-sm"
        />

        <input
          type="text"
          name="destino"
          placeholder="Destino"
          class="flex-1 border border-gray-300 rounded-lg px-4 py-3 text-sm"
        />

        <button
          type="submit"
          class="bg-primary hover:bg-primary/90 text-white rounded-full w-12 h-12 flex items-center justify-center shrink-0 self-center transition-colors"
          aria-label="Solicitar orçamento no WhatsApp"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ whatsappNumber }}>
  document.getElementById("hero-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
    const form = e.target;
    const tipo = form.tipo.value || "Não especificado";
    const origem = form.origem.value || "Não informada";
    const destino = form.destino.value || "Não informado";

    const msg = encodeURIComponent(
      `Olá! Gostaria de solicitar um orçamento.\n\nServiço: ${tipo}\nOrigem: ${origem}\nDestino: ${destino}`
    );

    window.open(`https://wa.me/${whatsappNumber}?text=${msg}`, "_blank");
  });
</script>
